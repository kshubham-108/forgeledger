# Copy to .env.local and fill in. With no env vars at all, the app runs in
# demo mode (data lives in the browser's localStorage) — everything below is
# optional until you want accounts and the daily pipeline.

# Supabase → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=

# Supabase → Project Settings → API → Project API keys → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase → Project Settings → API → Project API keys → service_role (KEEP SECRET — server-only, bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=

# Any long random string (e.g. `openssl rand -hex 32`); must match the CRON_SECRET GitHub Actions secret
CRON_SECRET=
